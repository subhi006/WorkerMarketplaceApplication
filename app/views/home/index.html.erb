<% if user_signed_in? %> 
  <div class="alert alert-success" role="alert">
    Welcome, <%= current_user.email %>
  </div>  

  <% if current_user.worker? %>
    <!-- Worker Role -->
    <%= render partial: "profile", locals: { user: current_user } %>
    <div class="mt-3">
      <%= link_to "View All Tasks", worker_tasks_path, class: "btn btn-primary" %>
    </div>
  <% else %>
    <!-- Contractor Role -->
    <%= render partial: "profile", locals: { user: current_user } %>
    <div class="mt-3">
      <%= link_to "View All Tasks", contractor_tasks_path, class: "btn btn-primary" %>
    </div>
    <div class="mt-3">
      <%= link_to "View All Applications", contractor_applications_path, class: "btn btn-secondary" %>
    </div>
    <div class="mt-3">
      <%= link_to "Create New Task", new_contractor_task_path, class: "btn btn-success" %>
    </div>
  <% end %>

  <div class="mt-4">
    <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "btn btn-danger" %>
  </div>
<% else %>
  <div class="mt-4">
    <%= button_to "Sign In", new_user_session_path, class: "btn btn-primary" %> 
  </div>
<% end %>
