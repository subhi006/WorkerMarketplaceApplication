<% if user_signed_in? %> 
  <!-- Welcome Message -->
  <div class="alert alert-success text-center" role="alert">
    Welcome, <%= current_user.email %>!
  </div> 

  <div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg" style="width: 100%; max-width: 1200px;">
      <div class="card-body text-center">
        <!-- Worker or Contractor Role Specific Links -->
        <% if current_user.worker? %>
          <%= render partial: "worker" %>
       <% else %>
          <%= render partial: "contractor" %>
       <% end %>

        <!-- Sign Out Button -->
        <div class="mt-4">
          <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "btn btn-danger btn-block" %>
        </div>
      </div>
    </div>
  </div>

<% else %>
  <!-- Not Signed In: Show Sign In and Sign Up Options -->
  <div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <!-- Larger Card Size (Max-width 800px) -->
    <div class="card shadow-lg" style="width: 100%; max-width: 800px;">
      <div class="card-body text-center">
        <div class="mt-4">
          <%= button_to "Sign In", new_user_session_path, class: "btn btn-primary btn-block mb-3" %> 
        </div>
      </div>
    </div>
  </div>
<% end %>
