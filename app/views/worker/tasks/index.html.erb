<%= render partial: "layouts/worker_header" %>
<%# search sector %>
<div>
<%= search_form_for [:worker, @q], remote: true do |f| %>
  <div class="d-flex flex-wrap justify-content-between align-items-center">
    <div class="mb-3">
      <%= f.label :location_cont, 'Location' %>
      <div class="input-group">
        <%= f.text_field :location_cont, class: "form-control", placeholder: "Enter location" %>
        <span class="input-group-text"><i class="bi bi-geo-alt"></i></span>
      </div>
    </div>
    
    <div class="mb-3">
      <%= f.label :company_cont, 'Company' %>
      <div class="input-group">
        <%= f.text_field :company_cont, class: "form-control", placeholder: "Enter company" %>
        <span class="input-group-text"><i class="bi bi-building"></i></span>
      </div>
    </div>

    <div class="mb-3">
      <%= f.label :category_id_eq, "Category" %>
      <%= f.collection_select :category_id_eq, Category.all, :id, :name, { include_blank: "Select category" }, class: "form-select" %>
    </div>
    
    <div class="mb-3">
      <%= f.submit "Search", class: "btn btn-primary w-100" %>
    </div>
  </div>
<% end %>

<!-- Include Bootstrap Icons for the location and company icons -->
<%= stylesheet_link_tag 'https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css' %>

</div>
<p id="notice"><%= notice %></p>
<%# task view %>
<h1>List of all Task</h1>
<table class="table table-bordered table-striped">
    <thead>
      <tr>
        <th>#</th>
        <th>Task Name</th>
        <th>Company</th>
        <th>Location</th>
      </tr>
    </thead>
    <tbody>
    <% if @task.present? %>
      <% @task.each_with_index do |per_task, index|%>
      <tr>
        <td><%= index + 1 %></td>
        <td>
          <%=per_task.category.name%>
        </td>
        <td>
         <%= per_task.company%>
        </td>
        <td>
         <%= per_task.location%>
        </td>
        <td>
            <%= link_to "view",worker_task_path(per_task), class: "btn btn-success btn-sm", method: :patch %>
        </td>
      </tr>
      <%end%>
    <%else%>
    <p>There is no task found!</p>
    <%end%>
      </tbody>
</table>
<% if can? :create, Task %>
  <p><%= link_to "create new task",new_contractor_task_path%></p>
<% end %>
<%= render partial: "layouts/con_footer"%>
