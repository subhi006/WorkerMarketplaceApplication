<%= render partial: "layouts/con_header" %>
<div class="card p-3 mb-3 shadow-sm">
  <p><strong>Task Category:</strong> <%= task.category.name %></p>
  <p><strong>Duration:</strong> <%= task.duration %></p>
  <p><strong>Location:</strong> <%= task.location %></p>
  <p><strong>Sift Timing:</strong> <%= task.sift %></p>
  <p><strong>Sift Hours:</strong> <%= task.sift_hours %></p>
  <p><strong>Job Mode:</strong> <%= task.job_mode %></p>
  <p><strong>Company:</strong> <%= task.company %></p>
  <p><strong>Description:</strong> <%= task.description %></p>
  <% if can? :update, task %>
    <% if task.unavailable? || task.status.blank?%>
        <%= button_to "post",task_post_contractor_task_path(task), formmethod: :post, data: { confirm: "Are you sure?" } %>
     <% else %>
     <p><strong>....Task is posted....</strong></p>
     <%end%>
    <%= link_to "Edit",edit_contractor_task_path%>
   <%end%>
   
</div>
