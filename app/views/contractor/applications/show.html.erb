<%= render partial: "layouts/con_header" %>

<%# <h1>Applications for <%= task.name</h1> %> 
<p><strong>Applications for</strong> <%= @task.category.name %></p>
<%# <p><strong>Description:</strong> <%= task.description %></p> 

<% if @application.present? %>
  <table class="table table-bordered table-striped">
    <thead>
      <tr>
        <th>#</th>
        <th>Candidate Name</th>
        <th>Contact Info</th>
        <th>Experience/Skills</th>
        <th>Application Date</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @application.each_with_index do |application, index| %>
        <tr>
          <td><%= index + 1 %></td>
          <td><%= application.worker.name %></td>
          <td><%= application.worker.contact_info %></td>
          <td><%= application.worker.skills || "Not Provided" %></td>
          <td><%= application.created_at.strftime("%d %b %Y") %></td>
          <td><%= application.status || "Pending" %></td>
          <td>
            <%= link_to "Approve", approve_application_path(application), class: "btn btn-success btn-sm", method: :patch %>
            <%= link_to "Reject", reject_application_path(application), class: "btn btn-danger btn-sm", method: :patch %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No applications found for this task.</p>
<% end %>
